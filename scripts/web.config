<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!-- Reverse Proxy: IIS HTTPS -> Rust API -->
    <rewrite>
      <rules>
        <rule name="ReverseProxyToRustAPI" stopProcessing="true">
          <match url="(.*)" />
          <action
            type="Rewrite"
            url="http://127.0.0.1:18080/{R:1}"
            appendQueryString="true" />
        </rule>
      </rules>
    </rewrite>

    <!-- ปิด directory browsing -->
    <directoryBrowse enabled="false" />

    <!-- จำกัดขนาด request body เช่น upload file -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>

    <!-- ให้ error จาก Rust API ผ่านกลับไป ไม่ให้ IIS แทนที่ response -->
    <httpErrors existingResponse="PassThrough" />

  </system.webServer>
</configuration>

{
  "lsp": {
    "rust-analyzer": {
      "binary": {
        "path": "rust-analyzer",
        "lookup_paths": ["$PATH"]
      },
      "initialization_options": {
        "cargo": {
          "allFeatures": false
        },
        "check": {
          "command": "clippy",
          "extraArgs": ["--", "-D", "warnings"]
        },
        "diagnostics": {
          "enable": true,
          "experimental": {
            "enable": false
          }
        },
        "inlayHints": {
          "enable": true,
          "typeHints": true,
          "parameterHints": true,
          "maxLength": 60
        }
      }
    }
  },
  "file_scan_exclusions": [
    "**/target/**",
    "**/.git/**",
    "**/node_modules/**",
    "**/data/**"
  ],
  "git": {
    "gitignore_entries": ["target/", "data/", ".env"]
  },
  "terminal": {
    "working_directory": "current_project_directory"
  }
}

{
  "title": "Kokkeak API — Production Overview",
  "uid": "kokkak-api-prod",
  "tags": ["kokkak", "api", "production"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": "$datasource",
        "query": "label_values(kube_pod_info{app_kubernetes_io_name=\"kokkak\"}, namespace)",
        "current": { "text": "kokkak-prod", "value": "kokkak-prod" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests / sec (5m avg)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"$namespace\"}[5m]))",
          "legendFormat": "rps"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error rate (5xx, 5m avg)",
      "datasource": "$datasource",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"$namespace\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{namespace=\"$namespace\"}[5m]))",
          "legendFormat": "5xx ratio"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Ready replicas",
      "datasource": "$datasource",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(kube_deployment_status_replicas_ready{namespace=\"$namespace\",deployment=~\"kokkak.*-api\"})",
          "legendFormat": "ready"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Rate-limit rejections / sec",
      "datasource": "$datasource",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"$namespace\",status=\"429\"}[5m]))",
          "legendFormat": "rate limited"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latency — p50 / p95 / p99",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{namespace=\"$namespace\"}[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "DB pool in-use vs free",
      "datasource": "$datasource",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(kokkak_db_pool_connections_in_use{namespace=\"$namespace\"}) by (role)",
          "legendFormat": "in_use {{role}}"
        },
        {
          "expr": "sum(kokkak_db_pool_connections_idle{namespace=\"$namespace\"}) by (role)",
          "legendFormat": "idle {{role}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "NATS queue lag (oldest pending)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, subject) (rate(nats_jetstream_consumer_delivery_lag_seconds_bucket{namespace=\"$namespace\"}[5m])))",
          "legendFormat": "p99 lag {{subject}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Readiness probe failures",
      "datasource": "$datasource",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(probe_failed_total{namespace=\"$namespace\", probe=~\".*readyz.*\"}[5m])) by (instance)",
          "legendFormat": "{{instance}}"
        }
      ]
    }
  ]
}

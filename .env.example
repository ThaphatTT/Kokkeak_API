# KOKKAK API — dev environment
# Copy to `.env` and edit for your local setup.
# M1.5+ uses KOKKAK_DATA_DIR__PATH for the JSON-DB simulation.
# M5+ wires real SQL Server; M12 adds multi-DB topology.

# ---- Server ----
KOKKAK_SERVER__ADDR=0.0.0.0:8080
KOKKAK_SERVER__WORKERS=4

# ---- Logging ----
KOKKAK_LOG__FORMAT=pretty   # or `json`

# ---- Auth (M2) ----
# REQUIRED in production. The server refuses to start when empty.
KOKKAK_AUTH__JWT_SECRET=please-change-me-to-a-long-random-string
KOKKAK_AUTH__ISSUER=kokkak-api
KOKKAK_AUTH__ACCESS_TTL_SECS=900         # 15 min
KOKKAK_AUTH__REFRESH_TTL_SECS=2592000    # 30 days

# ---- JSON-DB simulation (M1.5 / M2 / M3) ----
KOKKAK_DATA_DIR__PATH=./data/json_db
KOKKAK_DATA_DIR__RESET_ON_STARTUP=false  # set to `true` for clean dev runs

# ---- SQL Server (M5 + M12) ----
# Two equivalent ways to point at SQL Server:
#
# 1) Single-URL catch-all (M5 / M10 backwards-compat). Every
#    role (master / catalog / order / payment / log / report /
#    temp) shares the same pool.
#
# 2) Per-role URLs (M12, recommended for prod). Set the
#    per-role `*_URL` env vars; any role left blank inherits
#    the catch-all. Connection-string formats accepted:
#       ADO.NET:  Server=host;Database=db;User Id=u;Password=p
#       URL:      mssql://user:pass@host:1433/db?encrypt=true
#       JDBC:     jdbc:sqlserver://host:1433;database=db;user=u;password=p
#
# Leave the catch-all blank (and all role URLs blank) to use
# the JSON-DB simulation.
KOKKAK_DATABASE__SQLSERVER_URL=
# KOKKAK_DATABASE__MASTER_URL=
# KOKKAK_DATABASE__CATALOG_URL=
# KOKKAK_DATABASE__ORDER_URL=
# KOKKAK_DATABASE__PAYMENT_URL=
# KOKKAK_DATABASE__LOG_URL=
# KOKKAK_DATABASE__REPORT_URL=
# KOKKAK_DATABASE__TEMP_URL=
KOKKAK_DATABASE__POOL_SIZE=20
KOKKAK_DATABASE__CONNECT_TIMEOUT_SECS=5
KOKKAK_DATABASE__MIGRATIONS_DIR=./migrations

# ---- Optional services (leave disabled for pure JSON-DB dev) ----
# Redis (T07) — cache L2 + chat pub/sub backplane + worker
# idempotency. URL form: `redis://[:password@]host:port/db`.
# Common dev/staging setups:
#   - localhost, no auth:  redis://127.0.0.1:6379
#   - LAN server, no auth: redis://10.0.200.83:6379
#   - with auth:           redis://:secret@10.0.200.83:6379
#   - TLS:                 rediss://...
# `redis://disabled` (the default) keeps the system in JSON-DB
# mode and skips Redis from `/readyz`. Set a real URL to enable.
KOKKAK_REDIS__URL=redis://disabled
KOKKAK_REDIS__POOL_SIZE=16

KOKKAK_NATS__URL=nats://disabled
KOKKAK_NATS__STREAM_PREFIX=kokkak

KOKKAK_MONGO__URL=mongodb://disabled
KOKKAK_MONGO__DATABASE=kokkak

# ---- HTTP middleware (T-06) ----
# CORS allowlist (comma-separated). Empty (default) denies all
# cross-origin requests — the browser blocks them before they
# reach the server. Production deployments MUST set at least one
# origin (validated at startup, see validate() in config.rs).
# Example: https://app.example.com,https://admin.example.com
KOKKAK_MIDDLEWARE__CORS_ALLOW_ORIGINS=

# Maximum request duration in seconds. `0` disables the timeout
# entirely (NOT recommended for production — slow handlers will
# tie up tokio workers forever).
KOKKAK_MIDDLEWARE__REQUEST_TIMEOUT_SECS=30

# Response compression (gzip/deflate/br based on Accept-Encoding).
# Default `true`; the CPU cost is negligible and saves bandwidth
# for JSON-heavy mobile clients.
KOKKAK_MIDDLEWARE__COMPRESSION_ENABLED=true

# Per-IP rate limit (GCRA via tower_governor). Disabled by
# default in dev; production deployments should enable. 429
# responses include an `x-ratelimit-after` header with the
# GCRA deficit in seconds so well-behaved clients back off.
KOKKAK_MIDDLEWARE__RATE_LIMIT__ENABLED=false
KOKKAK_MIDDLEWARE__RATE_LIMIT__BACKEND=memory
KOKKAK_MIDDLEWARE__RATE_LIMIT__REQUESTS_PER_SECOND=100
KOKKAK_MIDDLEWARE__RATE_LIMIT__BURST_SIZE=200

# T-16: request body limit in bytes. Requests larger than this
# short-circuit with HTTP 413 (`Payload Too Large`) before the
# handler is invoked. Default 2 MiB (2097152). Raise for routes
# that accept large file uploads; set to 0 to reject all bodies
# (NOT recommended).
KOKKAK_MIDDLEWARE__REQUEST_BODY_LIMIT_BYTES=2097152

# T-16: maximum number of in-flight requests. New requests above
# this cap are immediately shed so the operator / load balancer
# can back off. Default 512 (sized for a 2-vCPU pod). Set higher
# on larger machines, or lower to be more aggressive about
# shedding load under attack.
KOKKAK_MIDDLEWARE__MAX_CONCURRENCY=512

# HTTP idempotency (T-14). When a mobile client retries a
# POST, the server replays the cached response so duplicate
# orders / payments / registrations never reach the DB.
# Default OFF in dev; production should enable. Matches the
# IETF `Idempotency-Key` draft and Stripe's contract.
KOKKAK_MIDDLEWARE__IDEMPOTENCY__ENABLED=false
KOKKAK_MIDDLEWARE__IDEMPOTENCY__TTL_SECS=86400
KOKKAK_MIDDLEWARE__IDEMPOTENCY__MAX_ENTRIES=10000

# ---- Deployment environment (T-11) ----
# `development` (default) — TLS optional, dev-friendly defaults.
# `production` — TLS required; empty CORS allowlist rejected.
KOKKAK_ENVIRONMENT=development

# ---- TLS / HTTPS (T-08..T-11) ----
# Set KOKKAK_TLS__ENABLED=true to serve over HTTPS instead of
# plain HTTP. In `production` env, this is enforced.
KOKKAK_TLS__ENABLED=false
KOKKAK_TLS__CERT_PATH=/etc/kokkak/cert.pem
KOKKAK_TLS__KEY_PATH=/etc/kokkak/key.pem
# Plain-HTTP listener that 308-redirects to HTTPS. Set to 0 to
# disable (typical dev: 0, typical prod: 80).
KOKKAK_TLS__REDIRECT_FROM_PORT=0
# HSTS max-age in seconds. 0 = HSTS off. Recommended for prod:
# 31536000 (1 year). We intentionally do NOT add
# `includeSubDomains` by default — audit every subdomain first.
KOKKAK_TLS__HSTS_MAX_AGE_SECS=0
# T-12: cert file watcher. When `true`, the service triggers a
# graceful shutdown on cert/key change so systemd/k8s restart
# picks up the new chain (LE 90-day rotation). Brief connection
# blip on each restart; default off.
KOKKAK_TLS__AUTO_RELOAD=false


KOKKAK_SERVER__ADDR=0.0.0.0:8080
KOKKAK_SERVER__WORKERS=4
KOKKAK_SERVER__PUBLIC_BASE_URL=
KOKKAK_LOG__FORMAT=pretty
KOKKAK_AUTH__JWT_SECRET=please-change-me-to-a-long-random-string
KOKKAK_AUTH__ISSUER=kokkak-api
KOKKAK_AUTH__ACCESS_TTL_SECS=900
KOKKAK_AUTH__REFRESH_TTL_SECS=2592000
KOKKAK_DATA_DIR__PATH=./data/json_db
KOKKAK_DATA_DIR__RESET_ON_STARTUP=false
KOKKAK_DATABASE__SQLSERVER_URL=
# KOKKAK_DATABASE__MASTER_URL=
# KOKKAK_DATABASE__CATALOG_URL=
# KOKKAK_DATABASE__ORDER_URL=
# KOKKAK_DATABASE__PAYMENT_URL=
# KOKKAK_DATABASE__LOG_URL=
# KOKKAK_DATABASE__REPORT_URL=
# KOKKAK_DATABASE__TEMP_URL=
KOKKAK_DATABASE__POOL_SIZE=20
KOKKAK_DATABASE__CONNECT_TIMEOUT_SECS=5
KOKKAK_DATABASE__MIGRATIONS_DIR=./migrations
KOKKAK_REDIS__URL=redis://disabled
KOKKAK_REDIS__POOL_SIZE=16
KOKKAK_NATS__URL=nats://disabled
KOKKAK_NATS__STREAM_PREFIX=kokkak
KOKKAK_MONGO__URL=mongodb://disabled
KOKKAK_MONGO__DATABASE=kokkak
KOKKAK_MIDDLEWARE__CORS_ALLOW_ORIGINS=
KOKKAK_MIDDLEWARE__REQUEST_TIMEOUT_SECS=30
KOKKAK_MIDDLEWARE__COMPRESSION_ENABLED=true
KOKKAK_MIDDLEWARE__RATE_LIMIT__ENABLED=false
KOKKAK_MIDDLEWARE__RATE_LIMIT__BACKEND=memory
KOKKAK_MIDDLEWARE__RATE_LIMIT__REQUESTS_PER_SECOND=100
KOKKAK_MIDDLEWARE__RATE_LIMIT__BURST_SIZE=200
KOKKAK_MIDDLEWARE__REQUEST_BODY_LIMIT_BYTES=2097152
KOKKAK_MIDDLEWARE__MAX_CONCURRENCY=512
KOKKAK_MIDDLEWARE__IDEMPOTENCY__ENABLED=false
KOKKAK_MIDDLEWARE__IDEMPOTENCY__TTL_SECS=86400
KOKKAK_MIDDLEWARE__IDEMPOTENCY__MAX_ENTRIES=10000
KOKKAK_ENVIRONMENT=development
KOKKAK_TLS__ENABLED=false
KOKKAK_TLS__CERT_PATH=/etc/kokkak/cert.pem
KOKKAK_TLS__KEY_PATH=/etc/kokkak/key.pem
KOKKAK_TLS__REDIRECT_FROM_PORT=0
KOKKAK_TLS__HSTS_MAX_AGE_SECS=0
KOKKAK_TLS__AUTO_RELOAD=false
KOKKAK_STORAGE__LOCAL_PATH=./data/uploads
# KOKKAK_STORAGE__S3_BUCKET=kokkak-uploads
# KOKKAK_STORAGE__S3_ENDPOINT=http://minio:9000
# KOKKAK_STORAGE__S3_REGION=us-east-1
# KOKKAK_STORAGE__S3_ACCESS_KEY=
# KOKKAK_STORAGE__S3_SECRET_KEY=
# KOKKAK_STORAGE__S3_PATH_STYLE=true

KOKKAK_STORAGE__SIGNED_URL_SECRET=please-change-me-to-a-long-random-string-min-32-bytes
KOKKAK_STORAGE__SIGNED_URL_TTL_SECS=600
KOKKAK_IMAGE__MAX_INPUT_BYTES=5242880
KOKKAK_IMAGE__MAX_DIMENSION_PX=2048
KOKKAK_IMAGE__WEBP_QUALITY=80

# KOKKAK API — dev environment
# Copy to `.env` and edit for your local setup.
# M1.5+ uses KOKKAK_DATA_DIR__PATH for the JSON-DB simulation
# (will be replaced by SQL Server in M5+).

# ---- Server ----
KOKKAK_SERVER__ADDR=0.0.0.0:8080
KOKKAK_SERVER__WORKERS=4

# ---- Logging ----
KOKKAK_LOG__FORMAT=pretty   # or `json`

# ---- Auth (M2) ----
# REQUIRED in production. The server refuses to start when empty.
KOKKAK_AUTH__JWT_SECRET=please-change-me-to-a-long-random-string
KOKKAK_AUTH__ISSUER=kokkak-api
KOKKAK_AUTH__ACCESS_TTL_SECS=900         # 15 min
KOKKAK_AUTH__REFRESH_TTL_SECS=2592000    # 30 days

# ---- JSON-DB simulation (M1.5 / M2 / M3) ----
KOKKAK_DATA_DIR__PATH=./data/json_db
KOKKAK_DATA_DIR__RESET_ON_STARTUP=false  # set to `true` for clean dev runs

# ---- Optional services (leave disabled for pure JSON-DB dev) ----
KOKKAK_DATABASE__SQLSERVER_URL=
KOKKAK_DATABASE__POOL_SIZE=20
KOKKAK_DATABASE__MIGRATIONS_DIR=./migrations

KOKKAK_REDIS__URL=redis://disabled
KOKKAK_REDIS__POOL_SIZE=16

KOKKAK_NATS__URL=nats://disabled
KOKKAK_NATS__STREAM_PREFIX=kokkak

KOKKAK_MONGO__URL=mongodb://disabled
KOKKAK_MONGO__DATABASE=kokkak
